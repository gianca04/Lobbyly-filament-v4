    {
      "id": "YPA8tDjm1QWwLT0LAWFfk",
      "type": "text",
      "x": -4028.6429915273484,
      "y": 5942.641359386813,
      "width": 2375.998779296875,
      "height": 585,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
