      "seed": 237526105,
      "version": 906,
      "versionNonce": 969364958,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1766942326486,
      "link": null,
      "locked": false,
      "text": "loans\n{\n    - id                 INT        ID único del préstamo\n    - user_id            INT        El ID de Juan Pérez.\n    - total_amount       DECIMAL    El monto total a devolver (Ej: 1200.00).\n    - interest_rate      DECIMAL    Tasa aplicada (Ej: 5.00).\n    - status             ENUM       Estado: pending (por aprobar), active (pagando), paid (liquidado), default (moroso).\n    - installment_total  INT        Número de cuotas totales\n    - created_at         DATETIME   Fecha en que se dio el dinero.\n    - grace_period_days  INT        Días de gracia.\n    - penalty_daily_rate DECIMAL    La tasa de castigo diario. Ejemplo: 0.70%\n    - penalty_base       ENUM       total_debt (sobre la deuda total) o capital.\n}",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "loans\n{\n    - id                 INT        ID único del préstamo\n    - user_id            INT        El ID de Juan Pérez.\n    - total_amount       DECIMAL    El monto total a devolver (Ej: 1200.00).\n    - interest_rate      DECIMAL    Tasa aplicada (Ej: 5.00).\n    - status             ENUM       Estado: pending (por aprobar), active (pagando), paid (liquidado), default (moroso).\n    - installment_total  INT        Número de cuotas totales\n    - created_at         DATETIME   Fecha en que se dio el dinero.\n    - grace_period_days  INT        Días de gracia.\n    - penalty_daily_rate DECIMAL    La tasa de castigo diario. Ejemplo: 0.70%\n    - penalty_base       ENUM       total_debt (sobre la deuda total) o capital.\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GrzcWiztTwCcoCB5Cp-xJ",
      "type": "text",
      "x": -3566.060910167578,
      "y": 6144.746620109345,
      "width": 4850.826462125185,
      "height": 1485,
      "angle": 0,
      "strokeColor": "#9c36b5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4c",
      "roundness": null,
      "seed": 424535,
      "version": 814,
      "versionNonce": 1976467914,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1767881260784,
      "link": null,
      "locked": false,
      "text": "installments\n{\n    - id                INT        ID único de la cuota.\n    - loan_id           INT        A qué préstamo pertenece.\n    - installment_num   INT        El número de cuota (1, 2, 3...).\n    - due_date          DATE       Cuándo vence (Ej: 2024-05-15).\n    - amount            DECIMAL    Cuánto debe pagar en esa cuota.\n    - status            VARCHAR    unpaid (pendiente), partial (parcial), paid (pagada), overdue (vencida) Si amount_paid == 0 → unpaid Si amount_paid > 0 PERO < amount → partial (Aquí vive el pago parcial) Si amount_paid >= amount → paid\n    - penalty_amount    DECIMAL    Monto acumulado por mora. Se actualiza cada noche.\n    - days_late         INT        Días de atraso reales (contador). // Pseudocódigo para calcular la mora diaria RAÍZ\n\nforeach ($cuotasVencidas as $cuota) {\n    // 1. Calcular días reales de atraso\n    $diasAtraso = fecha_hoy() - $cuota->due_date; \n    \n    // 2. Aplicar la regla del día de gracia (Imagen)\n    // Si el atraso es mayor al periodo de gracia (1 día), calculamos.\n    if ($diasAtraso > $cuota->loan->grace_period_days) {\n        \n        // 3. Definir los días efectivamente penalizables\n        // Ejemplo imagen: 5 días atraso - 1 gracia = 4 días a pagar.\n        $diasACobrar = $diasAtraso - $cuota->loan->grace_period_days;\n        \n        // 4. Calcular el monto diario (0.7% del total de la cuota)\n        $montoDiario = $cuota->amount * ($cuota->loan->penalty_daily_rate / 100);\n        \n        // 5. Actualizar la mora total\n        $cuota->penalty_amount = $montoDiario * $diasACobrar;\n        $cuota->days_late = $diasAtraso;\n        $cuota->save();\n    }\n}\n}",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "installments\n{\n    - id                INT        ID único de la cuota.\n    - loan_id           INT        A qué préstamo pertenece.\n    - installment_num   INT        El número de cuota (1, 2, 3...).\n    - due_date          DATE       Cuándo vence (Ej: 2024-05-15).\n    - amount            DECIMAL    Cuánto debe pagar en esa cuota.\n    - status            VARCHAR    unpaid (pendiente), partial (parcial), paid (pagada), overdue (vencida) Si amount_paid == 0 → unpaid Si amount_paid > 0 PERO < amount → partial (Aquí vive el pago parcial) Si amount_paid >= amount → paid\n    - penalty_amount    DECIMAL    Monto acumulado por mora. Se actualiza cada noche.\n    - days_late         INT        Días de atraso reales (contador). // Pseudocódigo para calcular la mora diaria RAÍZ\n\nforeach ($cuotasVencidas as $cuota) {\n    // 1. Calcular días reales de atraso\n    $diasAtraso = fecha_hoy() - $cuota->due_date; \n    \n    // 2. Aplicar la regla del día de gracia (Imagen)\n    // Si el atraso es mayor al periodo de gracia (1 día), calculamos.\n    if ($diasAtraso > $cuota->loan->grace_period_days) {\n        \n        // 3. Definir los días efectivamente penalizables\n        // Ejemplo imagen: 5 días atraso - 1 gracia = 4 días a pagar.\n        $diasACobrar = $diasAtraso - $cuota->loan->grace_period_days;\n        \n        // 4. Calcular el monto diario (0.7% del total de la cuota)\n        $montoDiario = $cuota->amount * ($cuota->loan->penalty_daily_rate / 100);\n        \n        // 5. Actualizar la mora total\n        $cuota->penalty_amount = $montoDiario * $diasACobrar;\n        $cuota->days_late = $diasAtraso;\n        $cuota->save();\n    }\n}\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
