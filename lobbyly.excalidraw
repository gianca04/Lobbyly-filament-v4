      "text": "score\n{\n- id\n- user_id INT\n- current_score VARCHAR | 0 – 300 → PÉRDIDA, 301 – 600 → DEFICIENTE, 601 – 700 → CPP, 701 – 800 → NORMAL, 801+→ NORMAL_PLUS\n}",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "score\n{\n- id\n- user_id INT\n- current_score VARCHAR | 0 – 300 → PÉRDIDA, 301 – 600 → DEFICIENTE, 601 – 700 → CPP, 701 – 800 → NORMAL, 801+→ NORMAL_PLUS\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
